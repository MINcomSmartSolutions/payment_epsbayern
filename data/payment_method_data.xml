<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
        <record id="payment_method_epsbayern" model="payment.method">
        <field name="name">ePayServiceBayern</field>
        <field name="code">epsbayern</field>
        <field name="sequence">100</field>
        <field name="active">False</field>
        <field name="image" type="base64" file="payment_epsbayern/static/description/icon.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">full_only</field>
                <field name="supported_country_ids"
               eval="[Command.set([
                         ref('base.de'),
                     ])]"
        />
        <field name="supported_currency_ids"
               eval="[Command.set([
                         ref('base.EUR'),
                     ])]"
        />
    </record>
</odoo>

