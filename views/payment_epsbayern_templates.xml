<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Redirect form: submits a GET to the EPS Bayern paypage URL with txnid as query param -->
    <template id="redirect_form">
        <form t-att-action="api_url" method="get">
            <input type="hidden" name="txnid" t-att-value="txnid"/>
        </form>
    </template>

    <!-- Inject a content div into the payment status page for JS to populate -->
    <template id="payment_status_inherit" inherit_id="payment.payment_status">
        <xpath expr="//div[@name='o_payment_status']" position="inside">
            <div class="o_payment_status_content"/>
        </xpath>
    </template>

</odoo>
