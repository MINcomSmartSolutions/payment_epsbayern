<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_transaction_form_epsbayern" model="ir.ui.view">
        <field name="name">payment.transaction.form.epsbayern</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <!-- Add "See Detailed Timeline" button in the header -->
            <xpath expr="//header" position="inside">
                <button name="action_fetch_txn_status_detail"
                        type="object"
                        string="See Detailed Timeline"
                        class="btn-secondary"
                        invisible="provider_code != 'epsbayern' or not provider_reference"
                        groups="base.group_system"/>
            </xpath>
        </field>
    </record>

</odoo>
